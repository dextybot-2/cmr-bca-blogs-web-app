<div class="fade-in">
    <div class="main-grid">
        <!-- Main Dashboard Content -->
        <div>
            <div class="card dashboard-card" style="position: relative; overflow: hidden;">
                <div style="background: var(--primary-pink); height: 100px; margin: -2rem -2rem 4rem -2rem;"></div>
                <div style="position: absolute; top: 50px; left: 2rem; display: flex; align-items: flex-end; gap: 1.5rem;">
                    <img src="<%= profile.avatar ? '/uploads/' + profile.avatar : 'https://ui-avatars.com/api/?name=' + profile.name + '&background=FF69B4&color=fff' %>" 
                         style="width: 100px; height: 100px; border-radius: 50%; border: 4px solid white; object-fit: cover; background: white;">
                    <div style="margin-bottom: 0.5rem;">
                        <h2 style="margin: 0;"><%= profile.name %> 🎀</h2>
                        <p style="margin: 0; color: var(--text-muted);">User ID: #<%= profile.id %></p>
                    </div>
                </div>
                
                <div style="margin-top: 1rem;">
                    <h4 class="sidebar-title">About Me 🌸</h4>
                    <p><%= profile.bio || "No bio yet. Tell us something sweet about yourself! ✨" %></p>
                </div>
            </div>

            <div style="margin-top: 2rem;">
                <h3 class="sidebar-title">Your Sweet Stories 🍦</h3>
                <div class="user-posts">
                    <% if (posts.length > 0) { %>
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem;">
                            <% posts.forEach(post => { %>
                                <div class="card" style="padding: 1rem;">
                                    <% if(post.image) { %>
                                        <img src="/uploads/<%= post.image %>" style="width: 100%; height: 150px; object-fit: cover; border-radius: var(--radius-sm); margin-bottom: 1rem;">
                                    <% } %>
                                    <h4 style="margin: 0.5rem 0;"><%= post.title %></h4>
                                    <p class="post-meta"><%= new Date(post.created_at).toLocaleDateString() %></p>
                                    <a href="/" class="btn btn-small" style="padding: 0.4rem 1rem; font-size: 0.8rem;">View</a>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="card" style="text-align: center;">
                            <p>You haven't shared any stories yet. <a href="/posts/create">Start now! 🌸</a></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Sidebar: Edit Profile -->
        <div class="sidebar">
            <div class="card">
                <h3 class="sidebar-title">Edit Profile ✨</h3>
                <form action="/user/update" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="name">Display Name</label>
                        <input type="text" id="name" name="name" class="form-control" value="<%= profile.name %>" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="bio">Bio 🌸</label>
                        <textarea id="bio" name="bio" class="form-control" rows="3" placeholder="Tell us something..."><%= profile.bio %></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="avatar">Avatar 📸</label>
                        <input type="file" id="avatar" name="avatar" class="form-control" accept="image/*">
                    </div>
                    
                    <button type="submit" class="btn btn-block">Save Changes 💖</button>
                </form>
            </div>

            <div class="card" style="background: var(--light-pink); color: var(--primary-pink); border: none;">
                <h4 style="margin: 0;">Quick Stats 📊</h4>
                <div style="display: flex; justify-content: space-around; margin-top: 1rem; text-align: center;">
                    <div>
                        <div style="font-size: 1.5rem; font-weight: 700;"><%= posts.length %></div>
                        <div style="font-size: 0.7rem; text-transform: uppercase;">Posts</div>
                    </div>
                    <div>
                        <div style="font-size: 1.5rem; font-weight: 700;">0</div>
                        <div style="font-size: 0.7rem; text-transform: uppercase;">Memories</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
